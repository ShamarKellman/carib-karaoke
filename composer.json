{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.3.5",
        "guzzlehttp/guzzle": "^7.10",
        "laravel/fortify": ">=1.36.1",
        "laravel/framework": "^12.54.1",
        "laravel/sanctum": "^4.3.1",
        "laravel/tinker": "^2.11.1",
        "livewire/livewire": "^4.2.1",
        "teamtnt/laravel-scout-tntsearch-driver": "^15.0.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.16.5",
        "fakerphp/faker": "^1.24.1",
        "filament/upgrade": "^5.3.5",
        "laravel/boost": "^2.3.1",
        "laravel/pint": "^1.29",
        "laravel/sail": "^1.53",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.1",
        "nunomaduro/larastan": "^3.9.3",
        "pestphp/pest": "^3.8.6",
        "pestphp/pest-plugin-laravel": "^3.2",
        "spatie/laravel-ignition": "^2.11"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "pint": "@php ./vendor/bin/pint --test",
        "format": "@php ./vendor/bin/pint",
        "stan": "./vendor/bin/phpstan analyse --memory-limit 1G",
        "test": "./vendor/bin/pest",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "branch-alias": {
            "dev-master": "12.x-dev"
        },
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
